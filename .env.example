PEEC_API_KEY=
PEEC_PROJECT_ID=
PEEC_MCP_URL=https://api.peec.ai/mcp
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Peec REST API
PEEC_API_URL=https://api.peec.ai/customer/v1

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Wire — execution layer
GITHUB_TOKEN=
GITHUB_REPO=
SLACK_WEBHOOK_URL=
NOTION_API_KEY=

# Composio MCP gateway
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=yappr-demo-user
NOTION_PARENT_PAGE_ID=
LINEAR_TEAM_ID=
PITCH_TO_EMAIL=

# Optional: lock /api/wire/cron-tick to only the Cloudflare Worker / Vercel Cron
# Set the same value here and in `wrangler secret put YAPPR_CRON_SECRET`
YAPPR_CRON_SECRET=

# Optional: local JSON persistence for saved Wire patches + schedules.
# Defaults to ./.yappr-data
YAPPR_DATA_DIR=
